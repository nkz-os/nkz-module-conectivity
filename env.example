# =============================================================================
# Connectivity - Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development
# =============================================================================

# Application
APP_NAME=Connectivity
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/connectivity

# Orion-LD (NGSI-LD Context Broker)
ORION_LD_URL=http://localhost:1026
CONTEXT_URL=http://localhost:5000/ngsi-ld-context.json

# CORS (for local development)
ALLOWED_ORIGINS=http://localhost:5003,http://localhost:5173

# API Gateway URL (for local dev proxying)
# VITE_API_URL=https://YOUR_DOMAIN
